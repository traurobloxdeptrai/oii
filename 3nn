function TrauHubLib:OnPasteClicked(button, input)
    button.Text = "✅"
    
    local clipboardText = ""
    local success = pcall(function()
        clipboardText = getclipboard()
    end)
    
    if success and clipboardText ~= "" then
        input.Text = clipboardText
        self:Notify("📋 Đã dán key từ clipboard!")
    else
        self:Notify("❌ Clipboard trống hoặc không hỗ trợ!")
    end
    
    task.wait(0.5)
    button.Text = "📋"
end

function TrauHubLib:OnGetKeyClicked(button, statusLabel)
    local originalText = button.Text
    button.Text = "⏳ Đang tạo..."
    statusLabel.Text = "🔗 Đang tạo link lấy key..."
    statusLabel.TextColor3 = self.Config.UI.Colors.Blue2
    
    local keyLink = self:CreateKeyLink()
    
    setclipboard(keyLink)
    
    button.Text = "✅ Đã Copy!"
    statusLabel.Text = "✅ Link đã được copy! Hoàn thành nhiệm vụ để nhận key."
    statusLabel.TextColor3 = self.Config.UI.Colors.Cyan
    
    self:Notify("🔗 Link lấy key đã được copy! Hoàn thành nhiệm vụ để nhận key.", 5)
    
    task.wait(2)
    button.Text = originalText
    statusLabel.Text = ""
end

function TrauHubLib:OnCheckKeyClicked(button, input, statusLabel, gui, blur)
    local key = input.Text
    
    if key == "" then
        self:Notify("❌ Vui lòng nhập key!")
        statusLabel.Text = "❌ Chưa nhập key"
        statusLabel.TextColor3 = self.Config.UI.Colors.Red
        return
    end
    
    local originalText = button.Text
    button.Text = "⏳ Đang kiểm tra..."
    statusLabel.Text = "🔍 Đang xác thực key..."
    statusLabel.TextColor3 = self.Config.UI.Colors.Blue2
    
    task.spawn(function()
        local success, message = self:VerifyKey(key)
        
        if success then
            button.Text = "✅ Thành công!"
            statusLabel.Text = "✅ " .. message
            statusLabel.TextColor3 = self.Config.UI.Colors.Cyan
            
            self:Notify("✅ Xác thực thành công! Đang tải Trẩu Hub...", 3)
            
            _G.KeyVerified = true
            
            task.wait(1)
            
            self:Tween(self.UI.Container, {
                Size = UDim2.new(0, 0, 0, 0)
            }, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In)
            
            task.wait(0.4)
            gui:Destroy()
            blur:Destroy()
        else
            button.Text = "❌ Thất bại"
            statusLabel.Text = "❌ " .. message
            statusLabel.TextColor3 = self.Config.UI.Colors.Red
            
            self:Notify("❌ " .. message, 3)
            
            for i = 1, 3 do
                self:Tween(self.UI.Container, {Position = UDim2.new(0.5, -10, 0.5, 0)}, 0.05)
                task.wait(0.05)
                self:Tween(self.UI.Container, {Position = UDim2.new(0.5, 10, 0.5, 0)}, 0.05)
                task.wait(0.05)
            end
            self:Tween(self.UI.Container, {Position = UDim2.new(0.5, 0, 0.5, 0)}, 0.05)
            
            task.wait(2)
            button.Text = originalText
        end
    end)
end

function TrauHubLib:OnLinkClicked(button, name, link)
    local originalText = button.Text
    button.Text = "✅"
    
    setclipboard(link)
    self:Notify("📋 Link " .. name .. " đã được copy!")
    
    task.wait(1)
    button.Text = originalText
end

function TrauHubLib:Init()
    self:CreateUI()
    return true
end

return TrauHubLib
