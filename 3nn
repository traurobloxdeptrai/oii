function TrauHubLib:GetHWID()
    return game:GetService("RbxAnalyticsService"):GetClientId()
end

function TrauHubLib:Tween(object, properties, duration, style, direction)
    local info = TweenInfo.new(
        duration or 0.3,
        style or Enum.EasingStyle.Quad,
        direction or Enum.EasingDirection.Out
    )
    local tween = TweenService:Create(object, info, properties)
    tween:Play()
    return tween
end

function TrauHubLib:Notify(message, duration)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Trẩu Hub",
        Text = message,
        Duration = duration or 3,
        Icon = "rbxassetid://104202858258775"
    })
end

function TrauHubLib:CreateKeyLink()
    local hwid = self:GetHWID()
    local url = self.Config.GitHub.GetKeyPage .. "?hwid=" .. HttpService:UrlEncode(hwid)
    
    local success, result = pcall(function()
        local apiUrl = string.format(
            "%s?api=%s&url=%s",
            self.Config.LinkShortener.API,
            self.Config.LinkShortener.APIKey,
            HttpService:UrlEncode(url)
        )
        local response = game:HttpGet(apiUrl)
        local data = HttpService:JSONDecode(response)
        return data.shortenedUrl or data.url or data.link
    end)
    
    return success and result or url
end

function TrauHubLib:VerifyKey(inputKey)
    inputKey = inputKey:gsub("^%s*(.-)%s*$", "%1")
    
    if not string.match(inputKey, "^" .. self.Config.KeyPrefix) then
        return false, "Định dạng key không đúng!"
    end
    
    local hwid = self:GetHWID()
    local url = self.Config.GitHub.KeysURL .. "?t=" .. os.time()
    
    local success, result = pcall(function()
        local response = game:HttpGet(url)
        local data = HttpService:JSONDecode(response)
        
        for _, keyData in ipairs(data.keys) do
            if keyData.key == inputKey and keyData.hwid == hwid then
                if keyData.status ~= "active" then
                    return false, "Key không còn hoạt động!"
                end
                
                if keyData.used == true then
                    return false, "Key đã được sử dụng!"
                end
                
                local now = os.date("!%Y-%m-%dT%H:%M:%S")
                if now > keyData.expires_at then
                    return false, "Key đã hết hạn!"
                end
                
                return true, "Xác thực thành công!"
            end
        end
        
        return false, "Key không hợp lệ!"
    end)
    
    if not success then
        return false, "Lỗi kết nối! Vui lòng thử lại."
    end
    
    return result
end

function TrauHubLib:CreateParticles(parent)
    local particles = Instance.new("Frame")
    particles.Name = "Particles"
    particles.Size = UDim2.new(1, 0, 1, 0)
    particles.BackgroundTransparency = 1
    particles.ZIndex = 0
    particles.Parent = parent
    
    for i = 1, 15 do
        local particle = Instance.new("Frame")
        particle.Size = UDim2.new(0, math.random(3, 8), 0, math.random(3, 8))
        particle.Position = UDim2.new(
            math.random(0, 100) / 100,
            0,
            math.random(0, 100) / 100,
            0
        )
        particle.BackgroundColor3 = self.Config.UI.Colors.Blue2
        particle.BackgroundTransparency = math.random(60, 90) / 100
        particle.BorderSizePixel = 0
        particle.Parent = particles
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = particle
        
        task.spawn(function()
            while particle.Parent do
                local duration = math.random(3, 6)
                local y = math.random(-50, 50)
                
                self:Tween(particle, {
                    Position = particle.Position + UDim2.new(0, 0, 0, y)
                }, duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                
                task.wait(duration)
            end
        end)
    end
end

